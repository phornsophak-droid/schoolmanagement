# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Supabase database configuration for cross-device synchronization
VITE_SUPABASE_URL=""
VITE_SUPABASE_ANON_KEY=""

# --- Telegram parent notifications (server-side only — set in Vercel, NOT VITE_) ---
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=""
# Secret string you invent; passed to setWebhook as secret_token and verified on
# every webhook call so only Telegram can reach /api/telegram-webhook.
TELEGRAM_WEBHOOK_SECRET=""
# Secret string you invent; Vercel Cron sends it as a Bearer token to protect
# /api/telegram-cron from being triggered by anyone.
CRON_SECRET=""
# Supabase SERVICE ROLE key (Project Settings → API). Server-only — bypasses RLS
# so the functions can read the locked-down telegram_links table. NEVER expose.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# Server-side Gemini key for the bot Q&A (Phase 3). A free Google AI Studio key
# works; can be the same value as VITE_GEMINI_API_KEY. If unset, the bot still
# links + sends absences but replies that Q&A isn't enabled.
GEMINI_API_KEY=""

# Optional: enables the "បង្កើនជាមួយ AI" wording on the School Summary (Reports).
# A FREE Google AI Studio key works (https://aistudio.google.com/apikey).
# Must be VITE_-prefixed to reach the browser. If unset, the summary still works
# fully offline (locally-computed text). Note: a client-side key is visible in
# the bundle — anyone could read it and use your quota.
VITE_GEMINI_API_KEY=""
